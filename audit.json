{
  "servers": [
    {
      "host": "127.0.0.1",
      "ports": [8080],
      "default": true,
      "error_pages": {
        "404": "error_pages/404.html"
      },
      "client_body_size_limit": 1048576,
      "routes": [
        {
          "path": "/ok",
          "methods": ["GET"],
          "root": "www",
          "index": "index.html"
        },
        {
          "path": "/uploads",
          "methods": ["GET", "POST", "DELETE"],
          "root": "www/uploads",
          "listing": true
        },
        {
          "path": "/temp",
          "methods": ["GET"],
          "redirection": "https://example.com"
        },
        {
          "path": "/cgi-bin",
          "methods": ["GET", "POST"],
          "root": "cgi-bin",
          "cgi": {
            ".py": "/usr/bin/python3"
          }
        }
      ]
    },
    {
      "host": "test.com",
      "ports": [8080],
      "routes": [
        {
          "path": "/",
          "methods": ["GET"],
          "root": "www",
          "index": "index.html"
        }
      ]
    }
  ]
}
